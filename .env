###############################################################################
# Grist Env Vars https://github.com/gristlabs/grist-core
###############################################################################

APP_HOME_URL=http://localhost:8484
# TODO: "You will need to place a “reverse proxy” in front of Grist to handle “SSL termination” (decrypting encypted traffic) using a certificate that establishes ownership of the site"
GRIST_HIDE_UI_ELEMENTS=helpCenter,billing
GRIST_PAGE_TITLE_SUFFIX=_blank
APP_STATIC_INCLUDE_CUSTOM_CSS=true 
# Set CSS File with: docker run -v $PWD/custom.css:/grist/static/custom.css

GRIST_FORCE_LOGIN=true
# GRIST_ANON_PLAYGROUND=false + denies anon access to shared docs
GRIST_SUPPORT_ANON=false 
# defaults to false
GRIST_ANON_PLAYGROUND=false 
# defaults to true

# Special Accounts (set to default values)
GRIST_DEFAULT_EMAIL=you@example.com
# Admin
GRIST_SUPPORT_EMAIL=support@getgrist.com
# Support powers

# SCIM
GRIST_ENABLE_SCIM=true
GRIST_SCIM_USER=scim@example.com

# Safe Sandbox for user-submitted python https://support.getgrist.com/self-managed/#how-do-i-sandbox-documents
GRIST_SANDBOX_FLAVOR=gvisor 

# OIDC https://support.getgrist.com/install/oidc/
GRIST_OIDC_IDP_ISSUER=http://host.docker.internal:9400/.well-known/openid-configuration
GRIST_OIDC_IDP_CLIENT_ID=AnyClientIDShouldWork
GRIST_OIDC_IDP_CLIENT_SECRET=AnyClientSecretShouldWork
GRIST_OIDC_SP_HOST=http://localhost:8484
GRIST_OIDC_IDP_SKIP_END_SESSION_ENDPOINT=true
